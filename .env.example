# JumpCloud
JC_API_KEY=
JC_ORG_ID=               # optional, MSP / multi-tenant only
# AI & SaaS Management: trailing usage window in days (1..90, default 30).
# The SaaS surface is skipped silently when not licensed.
JC_SAAS_USAGE_DAYS=30
# Steady request-rate cap (req/s) the JumpCloud client holds itself to across
# all collectors, so bursts don't trip 429s and eat exponential backoff. Empty
# ⇒ client default (8). Lower it if you still see 429s; raise it if your org's
# limit is higher and SaaS collection feels slow.
JC_MAX_RPS=

# Sophos Central
SOPHOS_CLIENT_ID=
SOPHOS_CLIENT_SECRET=

# Google Workspace
# Required scopes for the SA client ID (comma-separated, one line):
#   https://www.googleapis.com/auth/admin.directory.user.readonly,
#   https://www.googleapis.com/auth/admin.directory.user.security,
#   https://www.googleapis.com/auth/admin.directory.device.mobile.readonly,
#   https://www.googleapis.com/auth/admin.reports.audit.readonly,
#   https://www.googleapis.com/auth/spreadsheets
GWS_SA_JSON_PATH=
GWS_ADMIN_EMAIL=
GWS_CUSTOMER_ID=my_customer

# Output — Google Sheets
# Share the spreadsheet with the SA email as Editor.
# Leave SHEETS_SPREADSHEET_ID empty to skip the Sheets write entirely.
# Publish anytime from the last run's snapshot without re-collecting:
#   ./bin/inventory sheets               # all populated tabs
#   ./bin/inventory sheets --tabs jc,saas
SHEETS_SPREADSHEET_ID=
SHEETS_GW_WORKSHEET=GoogleWorkspace
SHEETS_JC_WORKSHEET=JumpCloud
SHEETS_SAAS_WORKSHEET=SaaS
SHEETS_SP_WORKSHEET=Sophos
SHEETS_MERGED_WORKSHEET=UsersAll
SHEETS_FINDINGS_WORKSHEET=Findings

# Storage tiers (snapshot store + drift baseline)
# LOCAL_DIR holds baseline/ current/ daily/ archive/.
# BASELINE_DIR defaults to LOCAL_DIR/baseline (classes.json, baseline.meta.json).
LOCAL_DIR=./local
BASELINE_DIR=

# LOCAL_PERSIST forces the storage mode. Leave empty to auto-detect: a
# GitHub-hosted runner (RUNNER_ENVIRONMENT=github-hosted) runs ephemerally and
# publishes to Sheets only; a self-hosted runner or a local machine persists the
# tiers above. Set true/false to override.
LOCAL_PERSIST=

# Drift digest hard byte budget for current/digest.json (default 50 KB).
DIGEST_MAX_BYTES=51200

# Behavior
# ENRICH_DELAY_S throttles per-user Google Workspace enrichment (seconds).
ENRICH_DELAY_S=0
RECENTLY_SEEN_DAYS=14
LOG_LEVEL=INFO
