# Keep the Docker build context small and free of secrets/runtime data.
.git/
.github/
*.md
!README.md

# Runtime storage (regenerated; may contain live org data)
local/current/
local/daily/
local/archive/

# Secrets
.env
.env.*
*-sa.json
*service-account*.json
secrets/

# Build artifacts
/inventory
/bin/
/dist/
*.test
coverage.out
coverage.html

# macOS / editor cruft
._*
.DS_Store
.idea/
.vscode/
